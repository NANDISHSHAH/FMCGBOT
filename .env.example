# FMCGBOT Environment Configuration Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (add it to .gitignore)

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Choose ONE of: openai, anthropic, gemini
# If not set, defaults to gemini (requires GOOGLE_API_KEY or GEMINI_API_KEY)

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# For Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-latest

# For Google Gemini
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-pro

# ============================================================================
# API Keys (Provider-Specific)
# ============================================================================
# Uncomment and set the key for your chosen provider

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
# Optional: point to an OpenAI-compatible endpoint (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini (use either one)
# GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# Web Search Configuration (Optional)
# ============================================================================
# If not set, web search defaults to curated mock corpus
# Supported providers: serpapi, tavily

# WEBSEARCH_PROVIDER=serpapi
# SERPAPI_API_KEY=your-serpapi-key-here

# WEBSEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your-tavily-key-here

# Web search timeout in seconds (default: 10)
# WEBSEARCH_TIMEOUT_SECONDS=10

# ============================================================================
# Unstructured Retrieval Configuration (Optional)
# ============================================================================
# Retrieval mode: tfidf (default), vector, or hybrid
# - tfidf: Fast TF-IDF lexical matching (no extra dependencies)
# - vector: OpenAI embeddings-based semantic search (requires OPENAI_API_KEY)
# - hybrid: Both methods blended (65% vector + 35% TF-IDF), fallback to TF-IDF if embeddings fail

DOC_RETRIEVAL_MODE=hybrid

# OpenAI embedding model (used for vector and hybrid modes)
# See: https://platform.openai.com/docs/guides/embeddings/embedding-models
OPENAI_EMBED_MODEL=text-embedding-3-small

# Embedding API timeout in seconds (default: 20)
# DOC_VECTOR_TIMEOUT_SECONDS=20

# Cache directory for embeddings (default: data/.cache)
# DOC_EMBEDDINGS_CACHE_DIR=data/.cache

# ============================================================================
# Session Memory Configuration (Optional)
# ============================================================================
# Backend: sqlite (default, persistent) or inmemory (in-process only)

SESSION_MEMORY_BACKEND=sqlite

# SQLite database path (default: data/session_memory.sqlite)
SESSION_MEMORY_DB_PATH=data/session_memory.sqlite

# ============================================================================
# Application Settings (Optional)
# ============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR (default: WARNING)
# LOG_LEVEL=INFO

# ============================================================================
# Development Settings
# ============================================================================
# Set to true to enable verbose output and debugging (default: false)
# DEBUG=false

# ============================================================================
# Notes
# ============================================================================
# 1. Mock Mode:
#    - No API key needed; agent runs with deterministic planners
#    - Disable specific providers by not setting their API keys
#
# 2. Live Mode Requirements:
#    - At least ONE provider API key must be set (openai, anthropic, or gemini)
#    - mock_mode=False in code will fail if no provider is configured
#
# 3. Web Search:
#    - Optional; defaults to curated mock corpus when not configured
#    - Set WEBSEARCH_PROVIDER and corresponding API key to enable live search
#
# 4. Retrieval Modes:
#    - tfidf: Works without any additional API keys
#    - vector/hybrid: Requires OPENAI_API_KEY and OPENAI_EMBED_MODEL
#    - Falls back gracefully if embeddings are unavailable
#
# 5. Session Memory:
#    - sqlite: Persisted across process restarts (default, production-ready)
#    - inmemory: Lost on restart (good for testing/development)
#
# 6. For Streamlit UI:
#    export LLM_PROVIDER=openai
#    export LLM_MODEL=gpt-4o-mini
#    export OPENAI_API_KEY=sk-...
#    streamlit run src/ui.py
#
# 7. For NAT Workflow:
#    export LLM_PROVIDER=openai
#    export LLM_MODEL=gpt-4o-mini
#    export OPENAI_API_KEY=sk-...
#    uv run nat run --config_file nat_workflow.yaml --input "..."
